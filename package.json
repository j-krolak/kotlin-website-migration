{
  "name": "kotlin-website-migration",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "ci": "react-router build",
    "format": "prettier .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@jetbrains/kotlin-web-site-ui": "3.1.0",
    "@react-hook/resize-observer": "^2.0.2",
    "@react-router/node": "^7.1.0",
    "@react-router/serve": "^7.1.0",
    "@rescui/button": "0.4.0",
    "@rescui/card": "0.3.0",
    "@rescui/checkbox": "0.1.0",
    "@rescui/colors": "0.0.4",
    "@rescui/icons": "0.3.0",
    "@rescui/input": "0.1.1",
    "@rescui/tab-list": "0.3.0",
    "@rescui/tooltip": "0.1.3",
    "@rescui/typography": "0.3.0",
    "@rescui/ui-contexts": "0.1.3",
    "body-scroll-lock": "4.0.0-beta.0",
    "classnames": "^2.5.1",
    "formik": "2.2.9",
    "highlight.js": "^11.11.1",
    "kotlin-playground": "^1.27.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.12.0",
    "sass-embedded": "^1.97.3",
    "isbot": "^5"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@react-router/dev": "7.12.0",
    "@types/node": "^22",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-classnames": "^0.9.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "react",
        "react-dom"
      ]
    },
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
